# Environment Configuration

# ============================================
# LICHESS API CONFIGURATION
# ============================================
# Get your API token from: https://lichess.org/account/oauth/token
# Scopes needed: puzzle:read, tournament:write, challenge:write

VITE_LICHESS_API_TOKEN=your_lichess_api_token_here
VITE_LICHESS_API_URL=https://lichess.org/api

# ============================================
# APPLICATION SETTINGS
# ============================================
VITE_APP_NAME=ChessHub Academy

# ============================================
# GOOGLE DRIVE GALLERY (OPTIONAL)
# ============================================
# 1. Share your Drive folder as "Anyone with the link can view"
# 2. Enable Drive API in Google Cloud Console
# 3. Create an unrestricted (or domain-restricted) API key
# 4. Paste the folder ID from the folder URL: drive.google.com/drive/folders/FOLDER_ID
VITE_GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here
VITE_GOOGLE_DRIVE_API_KEY=your_google_drive_api_key_here
# Auto-refresh interval in milliseconds (default: 300000 = 5 minutes)
VITE_GALLERY_REFRESH_INTERVAL=300000

# ============================================
# FEATURE FLAGS (Enable/Disable Features)
# ============================================
VITE_ENABLE_LICHESS_PUZZLES=true
VITE_ENABLE_TOURNAMENTS=false
VITE_ENABLE_GAME_ANALYSIS=false
VITE_ENABLE_RATING_TRACKER=false

# ============================================
# DEVELOPMENT SETTINGS
# ============================================
VITE_DEV_MODE=true

# ============================================
# SITE VERIFICATION (OPTIONAL)
# ============================================
# Google Search Console HTML tag token (content value only)
VITE_GOOGLE_SITE_VERIFICATION=
# Bing Webmaster Tools token (content value only)
VITE_BING_SITE_VERIFICATION=
