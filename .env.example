# Environment Configuration

# ============================================
# LICHESS API CONFIGURATION
# ============================================
# Get your API token from: https://lichess.org/account/oauth/token
# Scopes needed: puzzle:read, tournament:write, challenge:write

VITE_LICHESS_API_TOKEN=your_lichess_api_token_here
VITE_LICHESS_API_URL=https://lichess.org/api

# ============================================
# APPLICATION SETTINGS
# ============================================
VITE_APP_NAME=ChessHub Academy

# ============================================
# SUPABASE CONFIGURATION (REQUIRED)
# ============================================
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ============================================
# FEATURE FLAGS (Enable/Disable Features)
# ============================================
VITE_ENABLE_LICHESS_PUZZLES=true
VITE_ENABLE_TOURNAMENTS=false
VITE_ENABLE_GAME_ANALYSIS=false
VITE_ENABLE_RATING_TRACKER=false

# ============================================
# DEVELOPMENT SETTINGS
# ============================================
VITE_DEV_MODE=true
